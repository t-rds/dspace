                    <label>Sigla da instituição</label>
                    <input-type value-pairs-name="common_sigla_ies">dropdown</input-type>
                    <hint></hint>
                    <required></required>
                </field>
            </row>

            <row>
                <field>
                    <dc-schema>dc</dc-schema>
                    <dc-element>publisher</dc-element>
                    <dc-qualifier>department</dc-qualifier>
                    <repeatable>false</repeatable>
                    <label>Faculdade, Instituto ou Departamento</label>
                    <input-type value-pairs-name="common_department">dropdown</input-type>
                    <hint>Faculdade, Instituto ou Departamento.</hint>
                    <required></required>
                </field>
            </row>

            <row>
                <field>
                    <dc-schema>dc</dc-schema>
                    <dc-element>publisher</dc-element>
                    <dc-qualifier>program</dc-qualifier>
                    <repeatable>false</repeatable>
                    <label>Nome do curso ou programa de pós-graduação por extenso</label>
                    <input-type>onebox</input-type>
                    <hint>Nome do curso ou programa de pós-graduação por extenso.</hint>
                    <required></required>
                </field>
            </row>

            <row>
                <field>
                    <dc-schema>dc</dc-schema>
                    <dc-element>identifier</dc-element>
                    <dc-qualifier>ror</dc-qualifier>
                    <repeatable>false</repeatable>
                    <label>Identificador ROR</label>
                    <input-type>onebox</input-type>
                    <hint>Selecione o ROR da nossa instituição ou digite o identificador de outra instituição &lt;a href="https://ror.org/05bnh4739" target="_blank" &gt;(https://ror.org/05bnh4739)&lt;/a&gt;.</hint>
                    <required></required>
                    <!-- <default-value>https://ror.org/05bnh4739</default-value> -->
                </field>
            </row>
        </form>

        <!-- CC LICENSE -->
        <form name="direitosForm">
            <row>
                <field>
                    <dc-schema>dc</dc-schema>
                    <dc-element>rights</dc-element>
                    <dc-qualifier></dc-qualifier>
                    <repeatable>false</repeatable>
                    <label>Permissão de acesso</label>
                    <input-type value-pairs-name="rights">dropdown</input-type>
                    <hint>Para que o repositório possa disseminar sua produção científica, é necessário conceder o acesso aberto ao documento. Reserve um momento para ler os termos da licença disponíveis ao final do formulário.</hint>
                    <required>Para que o repositório possa disseminar sua produção científica, é necessário conceder o acesso aberto ao documento. Reserve um momento para ler os termos da licença disponíveis ao final do formulário.</required>
                </field>
                <field>
                    <dc-schema>dc</dc-schema>
                    <dc-element>rights</dc-element>
                    <dc-qualifier>uri</dc-qualifier>
                    <repeatable>false</repeatable>
                    <label>Licença Creative Commons (CC)</label>
                    <input-type value-pairs-name="cc_license_types">dropdown</input-type>
                    <hint>Associe uma licença Creative Commons 4.0 Internacional &lt;a href="https://creativecommons.org/licenses/" target="_blank" &gt;(https://creativecommons.org/licenses/)&lt;/a&gt; a este item.</hint>
                    <required>Tem que indicar uma licença Creative Commons! Caso não se aplique ou desconhecer pode selecionar a opção 'Não aplicável (N/A)'.</required>
                </field>
            </row>
        </form>

    </form-definitions>

