<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE input-forms SYSTEM "submission-forms.dtd">

<input-forms>

    <form-definitions>

        <!-- Form used for entering in Bitstream/File metadata after uploading a file -->
        <form name="bitstream-metadata">
            <row>
                <field>
                    <dc-schema>dc</dc-schema>
                    <dc-element>title</dc-element>
                    <dc-qualifier></dc-qualifier>
                    <repeatable>false</repeatable>
                    <label>Title</label>
                    <input-type>onebox</input-type>
                    <hint>Enter the name of the file.</hint>
                    <required>You must enter a name for this file</required>
                </field>
            </row>
            <row>
                <field>
                    <dc-schema>dc</dc-schema>
                    <dc-element>description</dc-element>
                    <repeatable>false</repeatable>
                    <label>Description</label>
                    <input-type>textarea</input-type>
                    <hint>Enter a description for the file</hint>
                    <required></required>
                </field>
            </row>
        </form>

        <form name="publicationStep">
            <row>
                <field>
                    <dc-schema>dc</dc-schema>
                    <dc-element>type</dc-element>
                    <dc-qualifier></dc-qualifier>
                    <repeatable>false</repeatable>
                    <label>Tipo do documento</label>
                    <input-type value-pairs-name="common_types">dropdown</input-type>
                    <hint>Selecione o tipo de conteúdo do item.</hint>
                    <required>Você deve selecionar o tipo de documento.</required>
                </field>
            </row>

            <row>
                <field>
                    <dc-schema>dc</dc-schema>
                    <dc-element>type</dc-element>
                    <dc-qualifier>intellectual</dc-qualifier> <repeatable>false</repeatable>
                    <label>Tipo de Produção Intelectual</label>
                    <type-bind>master thesis, doctoral thesis</type-bind>
                    <input-type value-pairs-name="tipo_producao_intelectual">dropdown</input-type>
                    <hint>Selecione a categoria que melhor descreve esta produção.</hint>
                    <required>Selecione um tipo de produção.</required>
                </field>
            </row>

            <!-- Título principal -->
            <row>
                <field>
                    <dc-schema>dc</dc-schema>
                    <dc-element>title</dc-element>
                    <dc-qualifier></dc-qualifier>
                    <language value-pairs-name="common_iso_languages">true</language>
                    <repeatable>false</repeatable>
                    <label>Título</label>
                    <input-type>onebox</input-type>
                    <hint>Informe o título do documento.</hint>
                    <required>Você deve inserir um título principal para este item.</required>
                </field>
            </row>

            <!-- Título alternativo -->
            <row>
                <field>
                    <dc-schema>dc</dc-schema>
                    <dc-element>title</dc-element>
                    <dc-qualifier>alternative</dc-qualifier>
                    <language value-pairs-name="common_iso_languages">true</language>
                    <repeatable>true</repeatable>
                    <label>Título alternativo</label>
                    <input-type>onebox</input-type>
                    <hint>Se o item tiver algum título alternativo (ex: tradução), insira-o aqui.</hint>
                    <required></required>
                </field>
            </row>

            <!-- Data de publicação / defesa -->
            <row>
                <field>
                    <dc-schema>dc</dc-schema>
                    <dc-element>date</dc-element>
                    <dc-qualifier>issued</dc-qualifier>
                    <repeatable>false</repeatable>
                    <label>Data de publicação / defesa</label>
                    <style>col-sm-6</style>
                    <input-type>date</input-type>
                    <hint>Forneça a data de publicação ou de defesa. Pode omitir dia e mês se não aplicável.</hint>
                    <required>Você deve inserir pelo menos o ano.</required>
                </field>
            </row>

            <!-- Idioma -->
            <row>
                <field>
                    <dc-schema>dc</dc-schema>
                    <dc-element>language</dc-element>
                    <dc-qualifier>iso</dc-qualifier>
                    <repeatable>false</repeatable>
                    <label>Idioma</label>
                    <input-type value-pairs-name="common_iso_languages">dropdown</input-type>
                    <hint>Idioma original do documento.</hint>
                    <required></required>
                </field>
            </row>

        </form>

        <form name="publicationPersonStep">
            <!-- == Relation-fields: vínculos com Entities == -->
            <!-- Autor(es) → vincula com Person Entity -->
            <row>
                <relation-field>
                    <relationship-type>isAuthorOfPublication</relationship-type>
                    <search-configuration>person</search-configuration>
                    <repeatable>true</repeatable>
                    <label>Autor(es)</label>
                    <hint>Busque pelo nome do autor já cadastrado como perfil (Entity Person) ou informe manualmente.</hint>
                    <linked-metadata-field>
                        <dc-schema>dc</dc-schema>
                        <dc-element>contributor</dc-element>
                        <dc-qualifier>author</dc-qualifier>
                        <input-type>onebox</input-type>
                    </linked-metadata-field>
                </relation-field>
            </row>

            <!-- Orientador → vincula com Person Entity -->
            <row>
                <relation-field>
                    <relationship-type>isAdvisorOfPublication</relationship-type>
                    <search-configuration>person</search-configuration>
                    <repeatable>true</repeatable>
                    <label>Orientador(es)</label>
                    <hint>Busque pelo nome do orientador já cadastrado ou informe manualmente.</hint>
                    <linked-metadata-field>
                        <dc-schema>dc</dc-schema>
                        <dc-element>contributor</dc-element>
                        <dc-qualifier>advisor</dc-qualifier>
                        <input-type>onebox</input-type>
                    </linked-metadata-field>
                </relation-field>
            </row>

            <!-- Coorientador → vincula com Person Entity -->
            <row>
                <relation-field>
                    <relationship-type>isCoAdvisorOfPublication</relationship-type>
                    <search-configuration>person</search-configuration>
                    <repeatable>true</repeatable>
                    <label>Coorientador(es)</label>
                    <hint>Busque pelo nome do coorientador já cadastrado ou informe manualmente.</hint>
                    <linked-metadata-field>
                        <dc-schema>dc</dc-schema>
                        <dc-element>contributor</dc-element>
                        <dc-qualifier>advisorco</dc-qualifier>
                        <input-type>onebox</input-type>
                    </linked-metadata-field>
                </relation-field>
            </row>

            <!-- Membros da Banca → vincula com Person Entity -->
            <row>
                <relation-field>
                    <relationship-type>isRefereeOfPublication</relationship-type>
                    <search-configuration>person</search-configuration>
                    <repeatable>true</repeatable>
                    <label>Membros da Banca</label>
                    <hint>Busque pelo nome do membro de banca já cadastrado ou informe manualmente.</hint>
                    <linked-metadata-field>
                        <dc-schema>dc</dc-schema>
                        <dc-element>contributor</dc-element>
                        <dc-qualifier>referee</dc-qualifier>
                        <input-type>onebox</input-type>
                    </linked-metadata-field>
                </relation-field>
            </row>
        </form>

        <form name="publicationMetadataStep">
            <!-- == Metadados descritivos == -->
            <!-- Resumo em português -->
            <row>
                <field>
                    <dc-schema>dc</dc-schema>
                    <dc-element>description</dc-element>
                    <dc-qualifier>resumo</dc-qualifier>
                    <language value-pairs-name="common_iso_languages">true</language>
                    <repeatable>false</repeatable>
                    <label>Resumo em Portguês</label>
                    <input-type>textarea</input-type>
                    <hint>Insira o resumo em português.</hint>
                    <required></required>
                </field>
            </row>

            <row>
                <field>
                    <dc-schema>dc</dc-schema>
                    <dc-element>description</dc-element>
                    <dc-qualifier>abstract</dc-qualifier>
                    <language value-pairs-name="common_iso_languages">true</language>
                    <repeatable>true</repeatable>
                    <label>Resumo em outro idioma</label>
                    <input-type>textarea</input-type>
                    <hint>Insira o resumo.</hint>
                    <required></required>
                </field>
            </row>

            <!-- Palavras-chave livres -->
            <row>
                <field>
                    <dc-schema>dc</dc-schema>
                    <dc-element>subject</dc-element>
                    <dc-qualifier></dc-qualifier>
                    <language value-pairs-name="common_iso_languages">true</language>
                    <repeatable>true</repeatable>
                    <label>Assunto(s)</label>
                    <style>col-sm-6</style>
                    <input-type>onebox</input-type>
                    <hint>Informe as palavras-chave. Tecle Enter para inserir individualmente. Mínimo 3, máximo 5.</hint>
                    <required>Mínimo 3 e no máximo 5 palavras-chave</required>
                </field>
            </row>

            <!-- Assuntos CNPq -->
            <row>
                <field>
                    <dc-schema>dc</dc-schema>
                    <dc-element>subject</dc-element>
                    <dc-qualifier>cnpq</dc-qualifier>
                    <repeatable>true</repeatable>
                    <label>Assunto(s) (CNPq)</label>
                    <input-type>onebox</input-type>
                    <hint>Selecione as categorias correspondentes na árvore do CNPq.</hint>
                    <required></required>
                    <vocabulary>cnpq</vocabulary>
                </field>
            </row>

            <!-- Citação ABNT -->
            <row>
                <field>
                    <dc-schema>dc</dc-schema>
                    <dc-element>identifier</dc-element>
                    <dc-qualifier>citation</dc-qualifier>
                    <repeatable>false</repeatable>
                    <label>Citação</label>
                    <input-type>textarea</input-type>
                    <hint>Insira a referência completa no padrão ABNT.</hint>
                    <required></required>
                </field>
            </row>

            <!-- DOI -->
            <row>
                <field>
                    <dc-schema>dc</dc-schema>
                    <dc-element>identifier</dc-element>
                    <dc-qualifier>doi</dc-qualifier>
                    <repeatable>false</repeatable>
                    <label>DOI</label>
                    <style>col-sm-6</style>
                    <type-bind>article, book</type-bind>
                    <input-type>onebox</input-type>
                    <hint>Identificador digital do objeto. Exemplo: https://doi.org/10.XXXX/XXXXX</hint>
                    <required></required>
                </field>
            </row>

            <!-- Nota -->
            <row>
                <field>
                    <dc-schema>dc</dc-schema>
                    <dc-element>description</dc-element>
                    <dc-qualifier>note</dc-qualifier>
                    <repeatable>false</repeatable>
                    <label>Nota</label>
                    <input-type>textarea</input-type>
                    <hint>Observações adicionais sobre o item.</hint>
                    <required></required>
                </field>
            </row>

            <!-- Agência de Fomento -->
            <row>
                <field>
                    <dc-schema>dc</dc-schema>
                    <dc-element>description</dc-element>
                    <dc-qualifier>sponsorship</dc-qualifier>
                    <repeatable>false</repeatable>
                    <label>Agência de Fomento</label>
                    <input-type>textarea</input-type>
                    <hint>Informe patrocinadores e/ou códigos de financiamento (ex: CAPES, CNPq, FAPERGS).</hint>
                    <required></required>
                </field>
            </row>

        </form>

        <form name="publicationOrgUnitStep">
            <!-- == Vínculo com OrgUnit == -->
            <!-- Instituição → vincula com OrgUnit Entity
                 (CORRIGIDO: repeatable true para co-tutela/dois depto.) -->
            <row>
                <relation-field>
                    <relationship-type>isOrgUnitOfPublication</relationship-type>
                    <search-configuration>orgunit</search-configuration>
                    <repeatable>true</repeatable>
                    <label>Instituição / Unidade</label>
                    <hint>Busque pela instituição ou unidade já cadastrada (Entity OrgUnit). Ex: "URI Erechim".</hint>
                    <linked-metadata-field>
                        <dc-schema>dc</dc-schema>
                        <dc-element>publisher</dc-element>
                        <dc-qualifier></dc-qualifier>
                        <input-type>onebox</input-type>
                    </linked-metadata-field>
                </relation-field>
            </row>

            <!-- Departamento / Área (campo livre complementar) -->
            <row>
                <field>
                    <dc-schema>dc</dc-schema>
                    <dc-element>publisher</dc-element>
                    <dc-qualifier>department</dc-qualifier>
                    <repeatable>false</repeatable>
                    <label>Faculdade, Instituto ou Departamento</label>
                    <input-type>onebox</input-type>
                    <hint>Ex: Departamento de Ciência da Computação, Departamento de Ciências da Saúde.</hint>
                    <required></required>
                </field>
            </row>

            <!-- Curso / Programa de Pós-Graduação -->
            <row>
                <field>
                    <dc-schema>dc</dc-schema>
                    <dc-element>publisher</dc-element>
                    <dc-qualifier>program</dc-qualifier>
                    <repeatable>false</repeatable>
                    <label>Curso ou Programa de Pós-Graduação</label>
                    <input-type>onebox</input-type>
                    <hint>Nome completo do curso ou PPG. Ex: Mestrado em Educação, Programa de Pós-Graduação em Saúde Coletiva.</hint>
                    <required></required>
                </field>
                <field>
                    <dc-schema>dc</dc-schema>
                    <dc-element>publisher</dc-element>
                    <dc-qualifier>programCode</dc-qualifier>
                    <repeatable>false</repeatable>
                    <label>Curso ou Programa de Pós-Graduação</label>
                    <type-bind>master thesis, doctoral thesis</type-bind>
                    <input-type>onebox</input-type>
                    <hint>Código do Programa de Pós-Graduação no Sistema Nacional de Pós-Graduação.</hint>
                    <required>Código único do Programa de Pós-Graduação stricto sensu no Sistema Nacional de Pós-Graduação, composto por 8 digítos iniciais referentes à Instituição de Ensino Superior e de Pesquisa e 5 dígitos subsequentes referentes ao Programa de Pós-Graduação.</required>
                </field>
            </row>

        </form>

        <form name="rightsStep">
            <!-- == Direitos de acesso == -->
            <row>
                <field>
                    <dc-schema>dc</dc-schema>
                    <dc-element>rights</dc-element>
                    <dc-qualifier></dc-qualifier>
                    <repeatable>false</repeatable>
                    <label>Permissão de acesso</label>
                    <input-type value-pairs-name="rights">dropdown</input-type>
                    <hint>Para disseminar sua produção científica, conceda acesso aberto sempre que possível.</hint>
                    <required>Você deve selecionar a permissão de acesso.</required>
                </field>
                <field>
                    <dc-schema>dc</dc-schema>
                    <dc-element>rights</dc-element>
                    <dc-qualifier>uri</dc-qualifier>
                    <repeatable>false</repeatable>
                    <label>Licença Creative Commons (CC)</label>
                    <input-type value-pairs-name="cc_license_types">dropdown</input-type>
                    <hint>Associe uma licença Creative Commons 4.0 Internacional &lt;a href="https://creativecommons.org/licenses" target="_blank"&gt;(https://creativecommons.org/licenses)&lt;/a&gt; a este item.</hint>
                    <required>Selecione uma licença CC ou a opção "Sem licença CC".</required>
                </field>
            </row>
        </form>

        <form name="personStep">

            <!-- Nome e Sobrenome na mesma linha -->
            <row>
                <field>
                    <dc-schema>person</dc-schema>
                    <dc-element>familyName</dc-element>
                    <dc-qualifier></dc-qualifier>
                    <repeatable>false</repeatable>
                    <label>Sobrenome</label>
                    <style>col-sm-6</style>
                    <input-type>onebox</input-type>
                    <hint>Sobrenome(s) do pesquisador.</hint>
                    <required>O sobrenome é obrigatório.</required>
                </field>
                <field>
                    <dc-schema>person</dc-schema>
                    <dc-element>givenName</dc-element>
                    <dc-qualifier></dc-qualifier>
                    <repeatable>false</repeatable>
                    <label>Nome</label>
                    <style>col-sm-6</style>
                    <input-type>onebox</input-type>
                    <hint>Nome(s) do pesquisador.</hint>
                    <required>O nome é obrigatório.</required>
                </field>
            </row>

            <!-- ORCID -->
            <row>
                <field>
                    <dc-schema>person</dc-schema>
                    <dc-element>identifier</dc-element>
                    <dc-qualifier>orcid</dc-qualifier>
                    <repeatable>false</repeatable>
                    <label>ID ORCID</label>
                    <input-type>onebox</input-type>
                    <hint>ORCID do pesquisador. Exemplo: &lt;a href="https://orcid.org" target="_blank"&gt;https://orcid.org/XXXX-XXXX-XXXX-XXXX&lt;/a&gt;. Recomenda-se cadastro em &lt;a href="https://orcid.org" target="_blank"&gt;https://orcid.org&lt;/a&gt;.</hint>
                    <required></required>
                </field>
            </row>

            <!-- Lattes -->
            <row>
                <field>
                    <dc-schema>person</dc-schema>
                    <dc-element>identifier</dc-element>
                    <dc-qualifier>lattes</dc-qualifier>
                    <repeatable>false</repeatable>
                    <label>ID Lattes</label>
                    <input-type>onebox</input-type>
                    <hint>URL do currículo Lattes. Exemplo: &lt;a href="https://buscatextual.cnpq.br/buscatextual/busca.do?metodo=apresentar" target="_blank"&gt;https://lattes.cnpq.br/XXXXXXXXXXXXXXXX&lt;/a&gt;.</hint>
                    <required></required>
                </field>
            </row>

            <row>
                <field>
                    <dc-schema>person</dc-schema>
                    <dc-element>identifier</dc-element>
                    <dc-qualifier>rid</dc-qualifier>
                    <repeatable>false</repeatable>
                    <label>Researcher ID</label>
                    <input-type>onebox</input-type>
                    <hint>ResearcherID do pesquisador. Exemplo: &lt;a href="https://researchid.co/search" target="_blank"&gt;https://researchid.co/ridXXXXXX&lt;/a&gt;.</hint>
                    <required></required>
                </field>
            </row>
            <row>
                <field>
                    <dc-schema>person</dc-schema>
                    <dc-element>identifier</dc-element>
                    <dc-qualifier>scopus-author-id</dc-qualifier>
                    <repeatable>false</repeatable>
                    <label>Scopus Author ID</label>
                    <input-type>onebox</input-type>
                    <hint>Scopus Author ID. Exemplo: &lt;a href="#" target="_blank"&gt;https://scopus.com/XXXXXX&lt;/a&gt;.</hint>
                    <required></required>
                </field>
            </row>

            <!-- E-mail institucional -->
            <row>
                <field>
                    <dc-schema>person</dc-schema>
                    <dc-element>email</dc-element>
                    <dc-qualifier></dc-qualifier>
                    <repeatable>false</repeatable>
                    <label>E-mail institucional</label>
                    <style>col-sm-6</style>
                    <input-type>onebox</input-type>
                    <hint>E-mail institucional do pesquisador (ex: nome@uricer.edu.br).</hint>
                    <required></required>
                </field>
            </row>

        </form>

        <form name="orgUnitStep">

            <!-- Nome oficial -->
            <row>
                <field>
                    <dc-schema>organization</dc-schema>
                    <dc-element>legalName</dc-element>
                    <dc-qualifier></dc-qualifier>
                    <repeatable>false</repeatable>
                    <label>Nome da Instituição / Unidade</label>
                    <input-type>onebox</input-type>
                    <hint>Nome completo. Ex: Universidade Regional Integrada do Alto Uruguai e das Missões</hint>
                    <required>O nome é obrigatório.</required>
                </field>
            </row>

            <!-- Sigla e Tipo na mesma linha -->
            <row>
                <field>
                    <dc-schema>organization</dc-schema>
                    <dc-element>acronym</dc-element>
                    <dc-qualifier></dc-qualifier>
                    <repeatable>false</repeatable>
                    <label>Sigla</label>
                    <style>col-sm-4</style>
                    <input-type>onebox</input-type>
                    <hint>Ex: URI, URI Erechim, UFRGS.</hint>
                    <required></required>
                </field>
                <!-- Tipo da unidade -->
                <field>
                    <dc-schema>organization</dc-schema>
                    <dc-element>type</dc-element>
                    <dc-qualifier></dc-qualifier>
                    <repeatable>false</repeatable>
                    <label>Tipo de Unidade</label>
                    <style>col-sm-8</style>
                    <input-type value-pairs-name="orgunit_types">dropdown</input-type>
                    <hint>Selecione o tipo da unidade organizacional.</hint>
                    <required></required>
                </field>
            </row>

            <!-- ROR -->
            <row>
                <field>
                    <dc-schema>organization</dc-schema>
                    <dc-element>identifier</dc-element>
                    <dc-qualifier>ror</dc-qualifier>
                    <repeatable>false</repeatable>
                    <label>Identificador ROR</label>
                    <input-type>onebox</input-type>
                    <hint>Ex: &lt;a href="https://ror.org/05bnh4739" target="_blank"&gt;https://ror.org/05bnh4739&lt;/a&gt; (URI Erechim).</hint>
                    <required></required>
                </field>
            </row>

            <!-- ISNI -->
            <row>
                <field>
                    <dc-schema>organization</dc-schema>
                    <dc-element>identifier</dc-element>
                    <dc-qualifier>isni</dc-qualifier>
                    <repeatable>false</repeatable>
                    <label>Identificador ISNI</label>
                    <input-type>onebox</input-type>
                    <hint>Ex: https://isni.org/isni/0000000110111626</hint>
                    <required></required>
                </field>
            </row>

            <!-- Cidade/Sede -->
            <row>
                <field>
                    <dc-schema>organization</dc-schema>
                    <dc-element>address</dc-element>
                    <dc-qualifier>addressLocality</dc-qualifier>
                    <repeatable>false</repeatable>
                    <label>Cidade / Sede</label>
                    <style>col-sm-6</style>
                    <input-type>onebox</input-type>
                    <hint>Ex: Erechim, RS.</hint>
                    <required></required>
                </field>
            </row>

            <!-- Website -->
            <row>
                <field>
                    <dc-schema>organization</dc-schema>
                    <dc-element>url</dc-element>
                    <dc-qualifier></dc-qualifier>
                    <repeatable>false</repeatable>
                    <label>Website</label>
                    <input-type>onebox</input-type>
                    <hint>Ex: https://uricer.edu.br</hint>
                    <required></required>
                </field>
            </row>

        </form>

    </form-definitions>

    <form-value-pairs>

        <!-- Tipos de publicação (valores COAR/DRIVER) -->
        <value-pairs value-pairs-name="common_types" dc-term="type">
            <pair>
                <displayed-value>Monografia / Trabalho de Conclusão de Curso (TCC)</displayed-value>
                <stored-value>bachelor thesis</stored-value>
            </pair>
            <pair>
                <displayed-value>Dissertação de Mestrado</displayed-value>
                <stored-value>master thesis</stored-value>
            </pair>
            <pair>
                <displayed-value>Tese de Doutorado</displayed-value>
                <stored-value>doctoral thesis</stored-value>
            </pair>
            <pair>
                <displayed-value>Artigo Científico</displayed-value>
                <stored-value>article</stored-value>
            </pair>
            <pair>
                <displayed-value>Artigo de Periódico</displayed-value>
                <stored-value>journal article</stored-value>
            </pair>
            <pair>
                <displayed-value>Trabalho em Anais de Evento</displayed-value>
                <stored-value>conference object</stored-value>
            </pair>
            <pair>
                <displayed-value>Livro</displayed-value>
                <stored-value>book</stored-value>
            </pair>
            <pair>
                <displayed-value>Capítulo de Livro</displayed-value>
                <stored-value>book part</stored-value>
            </pair>
            <pair>
                <displayed-value>Relatório Técnico</displayed-value>
                <stored-value>report</stored-value>
            </pair>
            <pair>
                <displayed-value>Outro tipo de documento</displayed-value>
                <stored-value>other</stored-value>
            </pair>
        </value-pairs>

        <!-- Idiomas -->
        <value-pairs value-pairs-name="common_iso_languages" dc-term="language_iso">
            <pair>
                <displayed-value>Português</displayed-value>
                <stored-value>por</stored-value>
            </pair>
            <pair>
                <displayed-value>English</displayed-value>
                <stored-value>eng</stored-value>
            </pair>
            <pair>
                <displayed-value>Spanish</displayed-value>
                <stored-value>spa</stored-value>
