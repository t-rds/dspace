<?xml version="1.0"?>
<!DOCTYPE input-forms SYSTEM "submission-forms.dtd">


<input-forms>

    <form-definitions>
        <!-- ITEM/TÍTULO/DATA/IDIOMA -->
        <form name="itemForm">
            <row>
                <field>
                    <dc-schema>dc</dc-schema>
                    <dc-element>type</dc-element>
                    <dc-qualifier></dc-qualifier>
                    <repeatable>false</repeatable>
                    <label>Tipo de documento</label>
                    <input-type value-pairs-name="common_types">dropdown</input-type>
                    <hint>Selecione o tipo de conteúdo do item.</hint>
                    <required>Você deve selecionar o tipo de documento.</required>
                </field>
            </row>

            <row>
                <field>
                    <dc-schema>dc</dc-schema>
                    <dc-element>title</dc-element>
                    <dc-qualifier></dc-qualifier>
                    <repeatable>false</repeatable>
                    <label>Título</label>
                    <input-type>onebox</input-type>
                    <hint>Informe o título do documento.</hint>
                    <required>Você deve inserir um título principal para este item.</required>
                </field>
            </row>

            <row>
                <field>
                    <dc-schema>dc</dc-schema>
                    <dc-element>title</dc-element>
                    <dc-qualifier>alternative</dc-qualifier>
                    <repeatable>true</repeatable>
                    <label>Título alternativo</label>
                    <input-type>onebox</input-type>
                    <hint>Se o item tiver algum título alternativo, por favor, insira-os aqui.</hint>
                    <required></required>
                </field>
            </row>

            <row>
                <field>
                    <dc-schema>dc</dc-schema>
                    <dc-element>date</dc-element>
                    <dc-qualifier>issued</dc-qualifier>
                    <repeatable>false</repeatable>
                    <label>Data da defesa</label>
                    <style>col-sm-6</style>
                    <input-type>date</input-type>
                    <hint>Por favor, forneça a data da publicação anterior ou distribuição pública.
                        Você pode omitir o dia e/ou mês se não forem aplicáveis.
                    </hint>
                    <required>Você deve inserir pelo menos o ano.</required>
                </field>
            </row>

            <row>
                <field>
                    <dc-schema>dc</dc-schema>
                    <dc-element>language</dc-element>
                    <dc-qualifier>iso</dc-qualifier>
                    <repeatable>false</repeatable>
                    <label>Idioma</label>
                    <input-type value-pairs-name="common_iso_languages">dropdown</input-type>
                    <hint>Idioma original do documento.</hint>
                    <required></required>
                </field>
            </row>
        </form>
        <!-- DADOS AUTOR -->
        <form name="autorForm">
            <row>
                <field>
                    <dc-schema>dc</dc-schema>
                    <dc-element>creator</dc-element>
                    <dc-qualifier></dc-qualifier>
                    <repeatable>true</repeatable>
                    <label>Autor</label>
                    <style>col-sm-6</style>
                    <input-type>name</input-type>
                    <hint>Informe o(s) Autor(es).</hint>
                    <required></required>
                </field>
            </row>

            <row>
                <field>
                    <dc-schema>dc</dc-schema>
                    <dc-element>creator</dc-element>
                    <dc-qualifier>lattes</dc-qualifier>
                    <repeatable>true</repeatable>
                    <label>Lattes do Autor</label>
                    <input-type>onebox</input-type>
                    <hint>Lattes do(s) autor(es). Exemplo: &lt;a href="https://buscatextual.cnpq.br/buscatextual/busca.do?metodo=apresentar" target="_blank" &gt;(https://lattes.cnpq.br/XXXXXXXXXXXXXXXX)&lt;/a&gt; a este item.</hint>
                    <required></required>
                </field>
                <field>
                    <dc-schema>dc</dc-schema>
                    <dc-element>creator</dc-element>
                    <dc-qualifier>id</dc-qualifier>
                    <repeatable>true</repeatable>
                    <label>ORCID do Autor</label>
                    <input-type>onebox</input-type>
                    <hint>ORCID(s) do(s) autor(es). Exemplo: &lt;a href="https://orcid.org" target="_blank" &gt;(https://orcid.org/XXXX-XXXX-XXXX-XXXX)&lt;/a&gt;.
                       Caso o pesquisador não possua cadastro no ORCID recomenda-se a sua realização: &lt;a href="https://orcid.org" target="_blank" &gt;(https://orcid.org)&lt;/a&gt;.</hint>
                    <required></required>
                </field>
            </row>
        </form>
        <!-- DADOS ORIENTADOR/COORIENTADOS -->
        <form name="orientadorForm">
            <row>
                <field>
                    <dc-schema>dc</dc-schema>
                    <dc-element>contributor</dc-element>
                    <dc-qualifier>advisor</dc-qualifier>
                    <repeatable>true</repeatable>
                    <label>Orientador</label>
                    <style>col-sm-6</style>
                    <input-type>name</input-type>
                    <hint>Informe o(s) Orientador(es).</hint>
                    <required></required>
                </field>
            </row>

            <row>
                <field>
                    <dc-schema>dc</dc-schema>
                    <dc-element>contributor</dc-element>
                    <dc-qualifier>advisorLattes</dc-qualifier>
                    <repeatable>true</repeatable>
                    <label>Lattes do Autor</label>
                    <input-type>onebox</input-type>
                    <hint>Lattes do(s) orientador(es). Exemplo: &lt;a href="https://buscatextual.cnpq.br/buscatextual/busca.do?metodo=apresentar" target="_blank" &gt;(https://lattes.cnpq.br/XXXXXXXXXXXXXXXX)&lt;/a&gt; a este item.</hint>
                    <required></required>
                </field>
                <field>
                    <dc-schema>dc</dc-schema>
                    <dc-element>contributor</dc-element>
                    <dc-qualifier>advisorID</dc-qualifier>
                    <repeatable>true</repeatable>
                    <label>ORCID do Autor</label>
                    <input-type>onebox</input-type>
                    <hint>ORCID(s) do Orientador(es). Exemplo: &lt;a href="https://orcid.org" target="_blank" &gt;(https://orcid.org/XXXX-XXXX-XXXX-XXXX)&lt;/a&gt;.
                       Caso o pesquisador não possua cadastro no ORCID recomenda-se a sua realização: &lt;a href="https://orcid.org" target="_blank" &gt;(https://orcid.org)&lt;/a&gt;.</hint>
                    <required></required>
                </field>
            </row>
        </form>
        <form name="coorientadorForm">
            <row>
                <field>
                    <dc-schema>dc</dc-schema>
                    <dc-element>contributor</dc-element>
                    <dc-qualifier>advisorco</dc-qualifier>
                    <repeatable>true</repeatable>
                    <label>Coorientador</label>
                    <style>col-sm-6</style>
                    <input-type>name</input-type>
                    <hint>Informe o(s) Autor(es).</hint>
                    <required></required>
                </field>
            </row>

            <row>
                <field>
                    <dc-schema>dc</dc-schema>
                    <dc-element>contributor</dc-element>
                    <dc-qualifier>advisorcoLattes</dc-qualifier>
                    <repeatable>true</repeatable>
                    <label>Lattes do Coorientador</label>
                    <input-type>onebox</input-type>
                    <hint>Informe o ID lattes do(s) coorientador. Exemplo: &lt;a href="https://buscatextual.cnpq.br/buscatextual/busca.do?metodo=apresentar" target="_blank" &gt;(https://lattes.cnpq.br/XXXXXXXXXXXXXXXX)&lt;/a&gt; a este item.</hint>
                    <required></required>
                </field>
                <field>
                    <dc-schema>dc</dc-schema>
                    <dc-element>contributor</dc-element>
                    <dc-qualifier>advisorcoID</dc-qualifier>
                    <repeatable>true</repeatable>
                    <label>ORCID do Coorientador</label>
                    <input-type>onebox</input-type>
                    <hint>Informe o(s) ORCID(s) do(s) coorientador(es). Exemplo: &lt;a href="https://orcid.org" target="_blank" &gt;(https://orcid.org/XXXX-XXXX-XXXX-XXXX)&lt;/a&gt;.
                       Caso o coorientador não possua cadastro no ORCID recomenda-se a sua realização: &lt;a href="https://orcid.org" target="_blank" &gt;(https://orcid.org)&lt;/a&gt;.</hint>
                    <required></required>
                </field>
            </row>
        </form>
        <!-- DADOS MEMBROS DA BANCA -->
        <form name="bancaForm">
            <row>
                <field>
                    <dc-schema>dc</dc-schema>
                    <dc-element>contributor</dc-element>
                    <dc-qualifier>referee</dc-qualifier>
                    <repeatable>true</repeatable>
                    <label>Membros da Banca</label>
                    <input-type>name</input-type>
                    <hint>Membro(s) da banca.</hint>
                    <required></required>
                </field>
            </row>

            <row>
                <field>
                    <dc-schema>dc</dc-schema>
                    <dc-element>contributor</dc-element>
                    <dc-qualifier>refereeLattes</dc-qualifier>
                    <repeatable>true</repeatable>
                    <label>Lattes do Membro da Banca</label>
                    <input-type>onebox</input-type>
                    <hint>Lattes do(s) coorientador. Exemplo: &lt;a href="https://buscatextual.cnpq.br/buscatextual/busca.do?metodo=apresentar" target="_blank" &gt;(https://lattes.cnpq.br/XXXXXXXXXXXXXXXX)&lt;/a&gt; a este item.</hint>
