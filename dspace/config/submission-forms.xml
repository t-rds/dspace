                    <label>ORCID do Membro da Banca</label>
                    <input-type>onebox</input-type>
                    <hint>ORCID(s) do(s) mebro(s) da banca. Exemplo: &lt;a href="https://orcid.org" target="_blank" &gt;(https://orcid.org/XXXX-XXXX-XXXX-XXXX)&lt;/a&gt;.
                       Caso o pesquisador não possua cadastro no ORCID recomenda-se a sua realização: &lt;a href="https://orcid.org" target="_blank" &gt;(https://orcid.org)&lt;/a&gt;.</hint>
                    <required></required>
                </field>
            </row>
        </form>
        <!-- XXXXX -->
        <form name="metadadosForm">
            <row>
                <field>
                    <dc-schema>dc</dc-schema>
                    <dc-element>description</dc-element>
                    <dc-qualifier>resumo</dc-qualifier>
                    <repeatable>false</repeatable>
                    <label>Resumo</label>
                    <input-type>textarea</input-type>
                    <hint>Insira o resumo do item.</hint>
                    <required></required>
                </field>
            </row>

            <row>
                <field>
                    <dc-schema>dc</dc-schema>
                    <dc-element>description</dc-element>
                    <dc-qualifier>abstract</dc-qualifier>
                    <repeatable>true</repeatable>
                    <label>Abstract/Resumen</label>
                    <input-type>textarea</input-type>
                    <hint>Insira o abstract do item.</hint>
                    <required></required>
                </field>
            </row>

            <row>
                <field>
                    <dc-schema>dc</dc-schema>
                    <dc-element>subject</dc-element>
                    <dc-qualifier></dc-qualifier>
                    <repeatable>true</repeatable>
                    <label>Assunto(s)</label>
                    <input-type>tag</input-type>
                    <hint>Informe as palavras-chave do documento descrito. Tecle enter para inserir individualmente as palavras. Devem ser indicadas no mínimo 3 e no máximo 5 palavras-chave por idioma.</hint>
                    <required>Mínimo 3 e no máximo 5 palavras-chave</required>
                </field>
            </row>

            <row>
                <field>
                    <dc-schema>dc</dc-schema>
                    <dc-element>subject</dc-element>
                    <dc-qualifier>cnpq</dc-qualifier>
                    <repeatable>true</repeatable>
                    <label>Assunto(s) (CNPq)</label>
                    <input-type>onebox</input-type>
                    <hint>Selecione as categorias correspondentes na árvore do CNPq.</hint>
                    <required></required>
                    <vocabulary>cnpq</vocabulary>
                </field>
            </row>

            <row>
                <field>
                    <dc-schema>dc</dc-schema>
                    <dc-element>identifier</dc-element>
                    <dc-qualifier>citation</dc-qualifier>
                    <repeatable>false</repeatable>
                    <label>Citação</label>
                    <input-type>textarea</input-type>
                    <hint>Insira a citação padrão ABNT.</hint>
                    <required></required>
                </field>
            </row>
        </form>

