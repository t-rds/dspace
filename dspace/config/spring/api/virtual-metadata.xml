<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xmlns:util="http://www.springframework.org/schema/util"
       xsi:schemaLocation="
           http://www.springframework.org/schema/beans
           http://www.springframework.org/schema/beans/spring-beans.xsd
           http://www.springframework.org/schema/util
           http://www.springframework.org/schema/util/spring-util.xsd"
       default-lazy-init="true">

    <!--
        ================================================================
        virtual-metadata.xml — URI Erechim / DSpace 9.x
        ================================================================
        Este arquivo configura quais metadados são VIRTUALIZADOS entre
        Entities relacionadas via relationship-types.xml.

        Conceito:
          - Quando uma Publication se relaciona com uma Person via
            "isAuthorOfPublication", os campos person.familyName e
            person.givenName da Person são concatenados e aparecem
            automaticamente como dc.contributor.author na Publication.
          - O dado NÃO é salvo duas vezes: existe só na Person e é
            exibido na Publication de forma virtual (calculado em tempo
            real pelo DSpace).

        Mapeamento completo implementado:
          isAuthorOfPublication    → dc.contributor.author (+ orcid, lattes)
          isAdvisorOfPublication   → dc.contributor.advisor (+ orcid, lattes)
          isCoAdvisorOfPublication → dc.contributor.advisorco (+ orcid, lattes)
          isRefereeOfPublication   → dc.contributor.referee (+ orcid, lattes)
          isOrgUnitOfPublication   → dc.publisher (nome da instituição)
          isOrgUnitOfPerson        → organization.legalName na Person (afiliação)

        Tipos de bean disponíveis:
          Concatenate : junta múltiplos campos em um só valor (ex: Sobrenome, Nome)
          Collected   : copia um campo diretamente (ex: person.identifier.orcid)
          Related     : encadeia relacionamentos (ex: Issue → Volume → Journal)
          UUIDValue   : expõe o UUID do item relacionado como metadado
        ================================================================
    -->

    <!-- ============================================================
         REGISTRO CENTRAL — VirtualMetadataPopulator
         Mapeia cada leftwardType do relationship-types.xml para
         o seu respectivo mapa de campos virtuais.
    ============================================================ -->
    <bean class="org.dspace.content.virtual.VirtualMetadataPopulator">
        <property name="map">
            <map>
                <!-- Publication ↔ Person -->
                <entry key="isAuthorOfPublication"    value-ref="isAuthorOfPublicationMap"/>
                <entry key="isAdvisorOfPublication"   value-ref="isAdvisorOfPublicationMap"/>
                <entry key="isCoAdvisorOfPublication" value-ref="isCoAdvisorOfPublicationMap"/>
                <entry key="isRefereeOfPublication"   value-ref="isRefereeOfPublicationMap"/>
                <!-- Publication ↔ OrgUnit -->
                <entry key="isOrgUnitOfPublication"   value-ref="isOrgUnitOfPublicationMap"/>
                <!-- Person ↔ OrgUnit -->
                <entry key="isOrgUnitOfPerson"        value-ref="isOrgUnitOfPersonMap"/>
            </map>
        </property>
    </bean>

    <!-- ============================================================
         FILTROS DE BUSCA POR ENTITY TYPE (Discovery / autocomplete)
         Usado nos relation-fields do submission-forms.xml para
         restringir a busca ao tipo correto de Entity.
    ============================================================ -->
    <bean class="org.dspace.content.virtual.EntityTypeToFilterQueryService">
        <property name="map">
            <map>
                <entry key="Publication" value="f.entityType=Publication,equals"/>
                <entry key="Person"      value="f.entityType=Person,equals"/>
                <entry key="OrgUnit"     value="f.entityType=OrgUnit,equals"/>
            </map>
        </property>
    </bean>


    <!-- ============================================================
         1. isAuthorOfPublication
         Person → Publication
         Virtualiza na Publication:
           dc.contributor.author   ← person.familyName + ", " + person.givenName
           person.identifier.orcid ← person.identifier.orcid (copiado)
           person.identifier.lattes← person.identifier.lattes (copiado)
    ============================================================ -->
    <util:map id="isAuthorOfPublicationMap">
        <entry key="dc.contributor.author"    value-ref="author_name"/>
        <entry key="dc.contributor.authorOrcid"  value-ref="author_orcid"/>
        <entry key="dc.contributor.authorLattes" value-ref="author_lattes"/>
    </util:map>

    <!--
        Concatena Sobrenome + ", " + Nome.
        useForPlace=true  : mantém a posição/ordem dos autores.
        populateWithNameVariant=true : usa variante de nome se cadastrada.
        Fallback: se person.familyName estiver vazio, usa organization.legalName
        (cobre casos de autores institucionais cadastrados como Person).
    -->
    <bean class="org.dspace.content.virtual.Concatenate" id="author_name">
        <property name="fields">
            <util:list>
                <value>person.familyName</value>
                <value>person.givenName</value>
            </util:list>
        </property>
        <property name="separator">
            <value>, </value>
        </property>
        <property name="useForPlace"            value="true"/>
        <property name="populateWithNameVariant" value="true"/>
    </bean>

    <!-- Copia o ORCID da Person para a Publication -->
    <bean class="org.dspace.content.virtual.Collected" id="author_orcid">
        <property name="fields">
            <util:list>
                <value>person.identifier.orcid</value>
            </util:list>
        </property>
    </bean>

    <!-- Copia o Lattes da Person para a Publication -->
    <bean class="org.dspace.content.virtual.Collected" id="author_lattes">
        <property name="fields">
            <util:list>
                <value>person.identifier.lattes</value>
            </util:list>
        </property>
    </bean>


    <!-- ============================================================
         2. isAdvisorOfPublication
         Person (orientador) → Publication
         Virtualiza na Publication:
           dc.contributor.advisor       ← Sobrenome, Nome do orientador
           person.identifier.orcid      ← ORCID do orientador
           person.identifier.lattes     ← Lattes do orientador

         Nota: usamos beans próprios (advisor_*) para que cada
         relacionamento tenha sua própria cadeia — evita colisão
         de valores entre Autor, Orientador e Coorientador.
    ============================================================ -->
    <util:map id="isAdvisorOfPublicationMap">
        <entry key="dc.contributor.advisor"       value-ref="advisor_name"/>
        <entry key="dc.contributor.advisorOrcid"  value-ref="advisor_orcid"/>
        <entry key="dc.contributor.advisorLattes" value-ref="advisor_lattes"/>
    </util:map>

    <bean class="org.dspace.content.virtual.Concatenate" id="advisor_name">
        <property name="fields">
            <util:list>
                <value>person.familyName</value>
                <value>person.givenName</value>
            </util:list>
        </property>
        <property name="separator">
            <value>, </value>
        </property>
        <property name="useForPlace"            value="true"/>
        <property name="populateWithNameVariant" value="true"/>
    </bean>

    <bean class="org.dspace.content.virtual.Collected" id="advisor_orcid">
        <property name="fields">
            <util:list>
                <value>person.identifier.orcid</value>
            </util:list>
        </property>
    </bean>

    <bean class="org.dspace.content.virtual.Collected" id="advisor_lattes">
        <property name="fields">
            <util:list>
                <value>person.identifier.lattes</value>
            </util:list>
        </property>
    </bean>


    <!-- ============================================================
         3. isCoAdvisorOfPublication
         Person (coorientador) → Publication
         Virtualiza na Publication:
           dc.contributor.advisorco     ← Sobrenome, Nome do coorientador
           person.identifier.orcid      ← ORCID do coorientador
           person.identifier.lattes     ← Lattes do coorientador
    ============================================================ -->
    <util:map id="isCoAdvisorOfPublicationMap">
        <entry key="dc.contributor.advisorco"       value-ref="coadvisor_name"/>
        <entry key="dc.contributor.advisorcoOrcid"  value-ref="coadvisor_orcid"/>
        <entry key="dc.contributor.advisorcoLattes" value-ref="coadvisor_lattes"/>
    </util:map>

    <bean class="org.dspace.content.virtual.Concatenate" id="coadvisor_name">
        <property name="fields">
            <util:list>
                <value>person.familyName</value>
                <value>person.givenName</value>
            </util:list>
        </property>
        <property name="separator">
            <value>, </value>
        </property>
        <property name="useForPlace"            value="true"/>
        <property name="populateWithNameVariant" value="true"/>
    </bean>

    <bean class="org.dspace.content.virtual.Collected" id="coadvisor_orcid">
        <property name="fields">
            <util:list>
                <value>person.identifier.orcid</value>
            </util:list>
        </property>
    </bean>

    <bean class="org.dspace.content.virtual.Collected" id="coadvisor_lattes">
        <property name="fields">
            <util:list>
                <value>person.identifier.lattes</value>
            </util:list>
        </property>
    </bean>


    <!-- ============================================================
         4. isRefereeOfPublication
         Person (membro de banca) → Publication
         Virtualiza na Publication:
           dc.contributor.referee       ← Sobrenome, Nome do membro
           person.identifier.orcid      ← ORCID do membro
           person.identifier.lattes     ← Lattes do membro
    ============================================================ -->
    <util:map id="isRefereeOfPublicationMap">
        <entry key="dc.contributor.referee"       value-ref="referee_name"/>
        <entry key="dc.contributor.refereeOrcid"  value-ref="referee_orcid"/>
        <entry key="dc.contributor.refereeLattes" value-ref="referee_lattes"/>
    </util:map>

    <bean class="org.dspace.content.virtual.Concatenate" id="referee_name">
        <property name="fields">
            <util:list>
                <value>person.familyName</value>
                <value>person.givenName</value>
            </util:list>
        </property>
        <property name="separator">
            <value>, </value>
        </property>
        <property name="useForPlace"            value="true"/>
        <property name="populateWithNameVariant" value="true"/>
    </bean>

    <bean class="org.dspace.content.virtual.Collected" id="referee_orcid">
        <property name="fields">
            <util:list>
                <value>person.identifier.orcid</value>
            </util:list>
        </property>
    </bean>

    <bean class="org.dspace.content.virtual.Collected" id="referee_lattes">
        <property name="fields">
            <util:list>
                <value>person.identifier.lattes</value>
            </util:list>
        </property>
    </bean>


    <!-- ============================================================
         5. isOrgUnitOfPublication
         OrgUnit → Publication
         Virtualiza na Publication:
           dc.publisher             ← organization.legalName (nome completo)
           dc.publisher.acronym     ← organization.acronym  (sigla, ex: URI Erechim)
           dc.identifier.ror        ← organization.identifier.ror (identificador ROR)

         Estes campos aparecem na página da Publication sem precisar
         ser digitados novamente — vêm direto do perfil OrgUnit.
    ============================================================ -->
    <util:map id="isOrgUnitOfPublicationMap">
        <entry key="dc.publisher"            value-ref="orgunit_pub_name"/>
        <entry key="dc.publisher.initials"   value-ref="orgunit_pub_initials"/>
        <entry key="dc.publisher.ror"        value-ref="orgunit_pub_ror"/>
        <entry key="dc.publisher.isni"       value-ref="orgunit_pub_isni"/>
    </util:map>

    <!-- Nome completo da instituição (ex: Universidade Regional Integrada...) -->
    <bean class="org.dspace.content.virtual.Collected" id="orgunit_pub_name">
        <property name="fields">
            <util:list>
                <value>organization.legalName</value>
            </util:list>
        </property>
    </bean>

    <!-- Sigla (ex: URI Erechim) -->
    <bean class="org.dspace.content.virtual.Collected" id="orgunit_pub_initials">
        <property name="fields">
            <util:list>
                <value>organization.acronym</value>
            </util:list>
        </property>
    </bean>

    <!-- Identificador ROR da instituição -->
    <bean class="org.dspace.content.virtual.Collected" id="orgunit_pub_ror">
        <property name="fields">
            <util:list>
                <value>organization.identifier.ror</value>
            </util:list>
        </property>
    </bean>

    <!-- Identificador ISNI da instituição -->
    <bean class="org.dspace.content.virtual.Collected" id="orgunit_pub_isni">
        <property name="fields">
            <util:list>
                <value>organization.identifier.isni</value>
            </util:list>
        </property>
    </bean>


    <!-- ============================================================
         6. isOrgUnitOfPerson
         OrgUnit → Person
         Virtualiza na Person:
           person.affiliation.name  ← organization.legalName
           person.affiliation.id    ← organization.identifier.ror

         Permite que o perfil do pesquisador exiba sua instituição
         de vínculo sem duplicar o dado — vem do perfil OrgUnit.
    ============================================================ -->
    <util:map id="isOrgUnitOfPersonMap">
        <entry key="person.affiliation.name" value-ref="orgunit_person_name"/>
        <entry key="person.affiliation.id"   value-ref="orgunit_person_ror"/>
    </util:map>

    <bean class="org.dspace.content.virtual.Collected" id="orgunit_person_name">
        <property name="fields">
            <util:list>
                <value>organization.legalName</value>
            </util:list>
        </property>
    </bean>

    <bean class="org.dspace.content.virtual.Collected" id="orgunit_person_ror">
        <property name="fields">
            <util:list>
                <value>organization.identifier.ror</value>
            </util:list>
        </property>
    </bean>

</beans>
